# Copier en .env sur la VM infra avant `docker compose up -d`.

# Identifiants Grafana (admin)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me-please

# PostgreSQL du Control Center (datasource Grafana, en LECTURE SEULE)
# Voir grafana_ro_user.sql pour créer l'utilisateur grafana_ro.
CPM_PG_HOST=129.104.125.190
CPM_PG_DB=control_center
CPM_PG_USER=grafana_ro
CPM_PG_PASSWORD=change-me-too

# --- Alertmanager / SMTP (envoi des alertes par e-mail) ---
# Alertmanager NE substitue PAS ces variables automatiquement : recopier ces valeurs
# dans monitoring/alertmanager/alertmanager.yml (smtp_* et adresses `to:`).
# Destinataires : à définir dans un second temps (equipe-infra / astreinte).
SMTP_HOST=smtp.polytechnique.fr
SMTP_PORT=587
SMTP_FROM=cloudpoolmanager@polytechnique.edu
SMTP_USER=change-me
SMTP_PASSWORD=change-me
ALERT_EMAIL_DEFAULT=equipe-infra@example.org
ALERT_EMAIL_CRITICAL=astreinte@example.org
