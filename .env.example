# ============================================
# vm-pool-managers — Environment Configuration
# ============================================
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# --- OpenStack (clouds.yaml) ---
OS_CLIENT_CONFIG_FILE=~/.config/openstack/clouds.yaml

# --- OpenStack : Projet VMs Étudiants (création/suppression VMs) ---
OS_CLOUD=ipp-idcs-vmpool

# --- OpenStack : Projet Infrastructure (listing images/flavors/networks) ---
# Laisser vide pour mode single-project (dev/test)
INFRA_OS_CLOUD=ipp-idcs-vmpoolmanager

# --- Control Center (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=control_center

# --- Control Center ---
CONTROL_CENTER_PORT=50051
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519
IP_ADDRESS=
# Mettre "true" pour désactiver le setup rclone (dev local / Mac)
SKIP_RCLONE=false

# --- Auto-suspend des VMs inactives (Phase 2) ---
# Suspend une VM assignée si aucune session utilisateur n'est ouverte depuis
# AUTOSUSPEND_IDLE_MINUTES minutes. Désactivé par défaut (mettre "true" pour armer).
# La reprise est manuelle (bouton ▶/resume) ; ManualOff empêche le crawler de relancer.
AUTOSUSPEND_ENABLED=false
AUTOSUSPEND_IDLE_MINUTES=60

# --- Hibernation nocturne (Phase 5) ---
# Suspend les VMs des pools (hors warm pool) pendant une plage horaire, chaque nuit.
# Format "début-fin" en heures 0-23 (ex. "22-7" = de 22h à 7h). Vide = désactivé.
# Les jours off (OffDays par pool) suspendent déjà toute la journée.
HIBERNATE_NIGHT=

# --- Jobs batch (Phase 4) ---
# Nombre de jobs de calcul exécutés en parallèle (file à priorités). Défaut 2.
BATCH_CONCURRENCY=2

# --- Quotas de stockage (Phase 5) ---
# Quota de stockage ALLOUÉ par utilisateur/pool, en Go (disque des flavors × VMs).
# Alerte au-delà. 0 = pas de quota.
STORAGE_QUOTA_GB=200

# --- Coûts & consommation (Phase 6) ---
# Tarifs unitaires pour l'estimateur et la page coût du mois. Valeurs indicatives.
PRICE_VCPU_HOUR=0.012
PRICE_GB_HOUR=0.006
PRICE_CURRENCY=€
# Lien vers un dashboard Grafana par VM (placeholder {ip}). Vide = bouton masqué.
# Ex. https://grafana.example/d/abcd/vm?var-instance={ip}
GRAFANA_VM_DASHBOARD=

# --- Microservice OpenStack ---
API_KEYNAME=
SECRET_KEY_JWT=CHANGE_ME
NETWORK_ID=

# Server defaults
SERVER_IMAGE_REF=
SERVER_FLAVOR_REF=
METADATA_SERVERPOOL_ID=pool_vms
METADATA_USER_ID=admin
METADATA_MIN_VM=2
METADATA_MAX_VM=9

# --- Guacamole (laisser vide pour désactiver le terminal SSH in-browser) ---
GUACAMOLE_URL=http://127.0.0.1:8080/guacamole
GUACAMOLE_ADMIN_USER=guacadmin
GUACAMOLE_ADMIN_PASS=CHANGE_ME
# Utilisateur Linux sur les VMs étudiantes (correspond au cloud-init baseUserConfig)
GUACAMOLE_SSH_USER=vmuser
# SSH_PRIVATE_KEY_PATH (déclaré ci-dessus) est réutilisé pour l'auth Guacamole

# --- Guacamole DB (docker-compose.guacamole.yaml) ---
GUAC_DB_ROOT_PASSWORD=CHANGE_ME
GUAC_DB_PASSWORD=CHANGE_ME

# --- VM Registrar (Phase 3) ---
# DSN PostgreSQL pour l'auto-enregistrement des VMs
# Les VMs doivent pouvoir joindre cette DB sur le réseau
# Laisser vide pour désactiver l'auto-registration
REGISTRAR_PG_DSN=postgres://admin:CHANGE_ME@IP_CONTROL_CENTER:5432/control_center?sslmode=disable
# URL HTTP du control center (port gRPC-Web / REST, ex. 50055) — pour ssh-monitor
REGISTRAR_CONTROL_CENTER_URL=http://IP_CONTROL_CENTER:50055
# --- GitHub OAuth (student portal login) ---
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_REDIRECT_URL=https://your-server/auth/github/callback

# --- Catalogue & affectations cours de l'X (endpoints DSI enseignement.polytechnique.fr) ---
# Le catalogue est PUBLIC (aucun token requis). Les affectations (profs/élèves, groupes)
# sont protégées par un token fixe (POST) + filtrage IP côté DSI.
# NE JAMAIS commiter le token : il reste dans .env (gitignoré).
XCOURSES_URL=https://www.enseignement.polytechnique.fr/data/moodle
XCOURSES_TOKEN=

# --- OpenTelemetry (observabilité : traces + métriques + logs) ---
# Endpoint OTLP/gRPC de l'OTel Collector (stack monitoring/). DOIT inclure le scheme
# (http:// = sans TLS, https:// = TLS). Vide → télémétrie désactivée (no-op).
# En dev (services Go natifs, collector en docker) : http://localhost:4317
# Sur la VM de prod (collector sur la VM infra) : http://<ip-infra>:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
# Attributs de ressource optionnels (ex. environnement) :
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod

# Port du endpoint Prometheus /metrics du microservice OpenStack (défaut :50053).
# À n'ouvrir qu'au réseau interne (scrapé par Prometheus), jamais sur Internet.
METRICS_PORT=:50053
