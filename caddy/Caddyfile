{
    debug
    order grpc_web before reverse_proxy
}

:443 {
    tls internal

    # ---------- gRPC-Web ----------
    handle_path /rpc/* {
        grpc_web
        reverse_proxy host.docker.internal:50051 {
            transport http {
                versions h2c
            }
        }
    }

    # ---------- REST API ----------
    handle /api/* {
        reverse_proxy host.docker.internal:50055
    }

    # ---------- Frontend ----------
    handle {
        reverse_proxy host.docker.internal:5173
    }
}
