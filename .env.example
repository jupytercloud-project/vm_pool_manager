# ============================================
# vm-pool-managers — Environment Configuration
# ============================================
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# --- OpenStack (clouds.yaml) ---
OS_CLIENT_CONFIG_FILE=~/.config/openstack/clouds.yaml

# --- OpenStack : Projet VMs Étudiants (création/suppression VMs) ---
OS_CLOUD=ipp-idcs-vmpool

# --- OpenStack : Projet Infrastructure (listing images/flavors/networks) ---
# Laisser vide pour mode single-project (dev/test)
INFRA_OS_CLOUD=ipp-idcs-vmpoolmanager

# --- Control Center (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=control_center

# --- Control Center ---
CONTROL_CENTER_PORT=50051
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519
IP_ADDRESS=
# Mettre "true" pour désactiver le setup rclone (dev local / Mac)
SKIP_RCLONE=false

# --- Microservice OpenStack ---
API_KEYNAME=
SECRET_KEY_JWT=CHANGE_ME
NETWORK_ID=

# Server defaults
SERVER_IMAGE_REF=
SERVER_FLAVOR_REF=
METADATA_SERVERPOOL_ID=pool_vms
METADATA_USER_ID=admin
METADATA_MIN_VM=2
METADATA_MAX_VM=9

# --- Guacamole (laisser vide pour désactiver le terminal SSH in-browser) ---
GUACAMOLE_URL=http://127.0.0.1:8080/guacamole
GUACAMOLE_ADMIN_USER=guacadmin
GUACAMOLE_ADMIN_PASS=CHANGE_ME
# Utilisateur Linux sur les VMs étudiantes (correspond au cloud-init baseUserConfig)
GUACAMOLE_SSH_USER=vmuser
# SSH_PRIVATE_KEY_PATH (déclaré ci-dessus) est réutilisé pour l'auth Guacamole

# --- Guacamole DB (docker-compose.guacamole.yaml) ---
GUAC_DB_ROOT_PASSWORD=CHANGE_ME
GUAC_DB_PASSWORD=CHANGE_ME

# --- VM Registrar (Phase 3) ---
# DSN PostgreSQL pour l'auto-enregistrement des VMs
# Les VMs doivent pouvoir joindre cette DB sur le réseau
# Laisser vide pour désactiver l'auto-registration
REGISTRAR_PG_DSN=postgres://admin:CHANGE_ME@IP_CONTROL_CENTER:5432/control_center?sslmode=disable
# URL HTTP du control center (port gRPC-Web / REST, ex. 50055) — pour ssh-monitor
REGISTRAR_CONTROL_CENTER_URL=http://IP_CONTROL_CENTER:50055
# --- GitHub OAuth (student portal login) ---
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_REDIRECT_URL=https://your-server/auth/github/callback

# --- Catalogue & affectations cours de l'X (endpoints DSI enseignement.polytechnique.fr) ---
# Le catalogue est PUBLIC (aucun token requis). Les affectations (profs/élèves, groupes)
# sont protégées par un token fixe (POST) + filtrage IP côté DSI.
# NE JAMAIS commiter le token : il reste dans .env (gitignoré).
XCOURSES_URL=https://www.enseignement.polytechnique.fr/data/moodle
XCOURSES_TOKEN=
